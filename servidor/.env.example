# ── Modo del servidor WebSocket ─────────────────────────────────────────────
# echo: devuelve el audio recibido (pruebas de conectividad)
# pipeline: STT + LLM + TTS completo
WS_MODO=pipeline

# ── STT ──────────────────────────────────────────────────────────────────────
# groq | local
STT_PROVIDER=groq

# ── LLM ──────────────────────────────────────────────────────────────────────
# groq | ollama
LLM_PROVIDER=groq

# ── Groq (STT + LLM en nube, gratis con límites) ─────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_LLM_MODEL=llama-3.1-8b-instant

# ── Ollama (LLM local, sin internet) ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Faster-Whisper (STT local) ───────────────────────────────────────────────
WHISPER_MODEL_SIZE=base

# ── Phase 5: handlers de comandos ────────────────────────────────────────────

# OpenWeatherMap — https://openweathermap.org/api (plan gratuito disponible)
OPENWEATHER_API_KEY=
CLIMA_CIUDAD_DEFAULT=Ciudad de México

# NewsAPI — https://newsapi.org (plan gratuito disponible)
NEWSAPI_KEY=
NOTICIAS_PAIS_DEFAULT=mx

# CoinGecko no requiere API key para uso básico

# El Toque — https://tasas.eltoque.com/docs (JWT de larga duración)
# Endpoint: GET /v1/trmi  Authorization: Bearer <token>
ELTOQUE_API_KEY=
