# Proveedor LLM activo: groq | ollama
LLM_PROVIDER=groq

# Groq (STT + LLM en nube, gratis con límites)
GROQ_API_KEY=gsk_...

# Modelo LLM de Groq
GROQ_LLM_MODEL=llama-3.1-8b-instant

# Ollama (LLM local, sin internet)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Faster-Whisper (STT local)
WHISPER_MODEL_SIZE=base
